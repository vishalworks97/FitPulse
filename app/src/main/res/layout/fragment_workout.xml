<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Workouts"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Active Session Card -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardActiveSession"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        app:cardBackgroundColor="#1A1A1A"
        app:cardCornerRadius="20dp"
        android:layout_marginBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="20dp"
            android:orientation="vertical"
            android:gravity="center">

            <TextView android:id="@+id/tvActiveExerciseName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Exercise Name" android:textColor="#00FF41" android:textStyle="bold"
                android:textSize="20sp"
                android:layout_marginBottom="8dp"/>

            <ImageView
                android:id="@+id/ivWorkoutGif"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="8dp"
                android:scaleType="centerInside"/>

            <Chronometer android:id="@+id/workoutTimer"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textColor="#FFFFFF" android:textSize="40sp" />

            <TextView android:id="@+id/tvLiveCalories"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="0 kcal" android:textColor="#8E8E8E" />

            <Button android:id="@+id/btnStartWorkout"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginTop="16dp" android:text="START"
                android:backgroundTint="#00FF41" android:textColor="#000000"/>

            <LinearLayout
                android:id="@+id/llActiveControls"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <Button android:id="@+id/btnPauseWorkout"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="PAUSE"
                    android:backgroundTint="#FFD740" android:textColor="#000000"
                    android:layout_marginEnd="8dp"/>

                <Button android:id="@+id/btnResumeWorkout"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="RESUME"
                    android:backgroundTint="#00FF41" android:textColor="#000000"
                    android:visibility="gone"
                    android:layout_marginEnd="8dp"/>

                <Button android:id="@+id/btnStopWorkout"
                    android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="SAVE"
                    android:backgroundTint="#FF4444" android:textColor="#FFFFFF"
                    android:visibility="gone"/>
            </LinearLayout>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWorkouts"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>